# Mapbox public token (free tier) — https://account.mapbox.com/access-tokens/
# Put this file next to package.json (project root). NOT inside app/.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# OpenWeather — `data/2.5/weather` + optional Maps 2.0 forecast tiles (timeline scrub, 3h UTC steps).
# Server probes: (1) 2.5 API (2) one Maps 2.0 tile. If (2) fails, overlay falls back to legacy “current” tiles only.
# Maps 2.0 may require a paid / product entitlement even when 2.5 works.
# https://openweathermap.org/api/weather-map-2 — restart `npm run dev` after changes.
OPENWEATHER_API_KEY=
